<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title><%= article?.title || 'ニュース詳細' %> - はとあげマート</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="はとあげマーケットのニュース詳細ページです。">
  <link rel="stylesheet" href="/style.css?v=20260301">
  <script defer src="/script.js?v=20260301"></script>
  <link rel="icon" href="/assets/favicon.ico">
</head>
<body>
<%- include("partials/header") %>

<main class="news-main">
  <a href="/news" class="news-back">← ニュース一覧へ戻る</a>

  <% if (error) { %>
    <p class="news-error"><%= error %></p>
  <% } %>

  <article class="news-post news-post-detail">
    <% if (article) { %>
      <header class="news-post-header">
        <time datetime="<%= article.date %>" class="news-date"><%= article.date %></time>
        <h1><%= article.title %></h1>
        <p class="news-uuid">記事ID: <%= article.uuid || article.id %></p>
      </header>
      <p class="news-body"><%= article.body || "本文は準備中です。" %></p>
    <% } else { %>
      <header class="news-post-header">
        <h1>記事を表示できませんでした</h1>
      </header>
      <p class="news-body">本文は準備中です。</p>
    <% } %>
  </article>
</main>

<%- include("partials/footer") %>
</body>
</html>
